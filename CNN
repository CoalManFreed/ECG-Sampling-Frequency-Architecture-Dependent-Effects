def build_cnn_ablation_summary(results):
    rows = []
    for prof in results["profiles"]:
        freq = label_short(prof["label"])
        rows.append({
            "Label": prof["label"],
            "Frequency": freq,
            "Model": prof.get("model_name", ""),
            "Train Fraction": prof.get("train_fraction", 1.0),
            "Params": prof["n_params"],
            "Receptive Field (samples)": prof.get("effective_receptive_field_samples", np.nan),
            "ROC-AUC Macro": prof["metrics"]["roc_auc_macro"],
            "PR-AUC Macro": prof["metrics"]["pr_auc_macro"],
            "Accuracy": prof["metrics"]["accuracy"],
            "Train Time (s)": prof["train_wall_s"],
        })
    return pd.DataFrame(rows)


def build_results_section(results, dataset_class_counts: pd.Series):
    primary_profiles = get_primary_profiles(results)
    ablation_df = build_cnn_ablation_summary(results)

    lines = []
    lines.append("## 5. Results\n")
    lines.append(
        "This section summarizes dataset composition, model discrimination across sampling frequencies, "
        "per-class classification performance, computational cost, and CNN sensitivity analyses. "
        f"Overall performance metrics include 95% bootstrapped confidence intervals ({N_BOOTSTRAP} resamples). "
        "Main performance tables and figures are reported for the baseline CNN trained on the full dataset, "
        "while the full CNN ablation and learning-curve analyses are summarized separately.\n"
    )

    lines.append("### 5.1 Dataset Characteristics\n")
    class_df = pd.DataFrame({
        "Class": TARGET_SUPER,
        "Count": [int(dataset_class_counts.get(c, 0)) for c in TARGET_SUPER]
    })
    lines.append(
        "Table 1 summarizes the number of ECGs assigned to each diagnostic superclass in the filtered PTB-XL cohort used for model development.\n"
    )
    lines.append(make_markdown_table(class_df, float_cols=[]))
    lines.append("\n")

    lines.append("### 5.2 Baseline CNN Performance by Sampling Frequency\n")
    perf_rows = []
    for prof in primary_profiles:
        roc_ci = prof["bootstrap_cis"]["roc_auc_macro"]
        pr_ci = prof["bootstrap_cis"]["pr_auc_macro"]
        acc_ci = prof["bootstrap_cis"]["accuracy"]

        perf_rows.append({
            "Frequency": label_short(prof["label"]),
            "ROC-AUC (95% CI)": f"{prof['metrics']['roc_auc_macro']:.3f} ({roc_ci['ci_lower']:.3f}-{roc_ci['ci_upper']:.3f})",
            "PR-AUC (95% CI)": f"{prof['metrics']['pr_auc_macro']:.3f} ({pr_ci['ci_lower']:.3f}-{pr_ci['ci_upper']:.3f})",
            "Accuracy (95% CI)": f"{prof['metrics']['accuracy']:.3f} ({acc_ci['ci_lower']:.3f}-{acc_ci['ci_upper']:.3f})",
            "Params": prof["n_params"],
        })
    perf_df = pd.DataFrame(perf_rows)
    lines.append(
        "Table 2 compares baseline CNN classification performance across the three sampling frequencies. "
        "ROC-AUC and PR-AUC are reported as macro-averaged values, and accuracy is reported as exact-match "
        "multilabel accuracy. Values in parentheses are 95% bootstrapped confidence intervals.\n"
    )
    lines.append(perf_df.to_markdown(index=False))
    lines.append("\n")

    lines.append("### 5.3 Baseline CNN Per-Class Performance\n")
    lines.append(
        "Table 3 shows class-specific precision, recall, F1 score, and per-class ROC-AUC for the baseline "
        "CNN at each sampling frequency. Bootstrapped 95% confidence intervals are provided for per-class ROC-AUC and F1.\n"
    )

    for prof in primary_profiles:
        freq = label_short(prof["label"])

        perf_df = pd.DataFrame(prof["per_class_metrics"]).rename(columns={"F1": "F1_point"})
        ci_df = pd.DataFrame(prof["per_class_bootstrap_cis"]).rename(columns={"F1": "F1_ci_point"})

        merged = perf_df.merge(ci_df, on="Class", how="left")

        merged["F1 (95% CI)"] = merged.apply(
            lambda r: f"{r['F1_point']:.3f} ({r['F1 CI Lower']:.3f}-{r['F1 CI Upper']:.3f})",
            axis=1
        )
        merged["ROC-AUC (95% CI)"] = merged.apply(
            lambda r: f"{r['ROC-AUC']:.3f} ({r['ROC-AUC CI Lower']:.3f}-{r['ROC-AUC CI Upper']:.3f})",
            axis=1
        )

        show_df = merged[["Class", "Precision", "Recall", "F1 (95% CI)", "ROC-AUC (95% CI)"]].copy()
        show_df["Precision"] = show_df["Precision"].map(lambda x: f"{x:.3f}")
        show_df["Recall"] = show_df["Recall"].map(lambda x: f"{x:.3f}")

        lines.append(f"**{freq}**\n")
        lines.append(show_df.to_markdown(index=False))
        lines.append("\n")

    lines.append("### 5.4 Baseline CNN Computational Cost\n")
    cost_rows = []
    for prof in primary_profiles:
        inf64 = None
        for item in prof["inference"]:
            if item["batch_size"] == 64:
                inf64 = item
                break
        if inf64 is None:
            inf64 = prof["inference"][0]

        gpu_peak = None
        if prof["gpu_mem_after"] is not None:
            gpu_peak = prof["gpu_mem_after"].get("peak_mb", None)

        cost_rows.append({
            "Frequency": label_short(prof["label"]),
            "Training Time (s)": prof["train_wall_s"],
            "RAM (MB)": prof["rss_mb_after"],
            "Inference (ms/sample)": inf64["ms_per_sample"],
            "GPU Peak (MB)": gpu_peak if gpu_peak is not None else np.nan,
        })

    cost_df = pd.DataFrame(cost_rows)
    lines.append(
        "Table 4 reports computational cost by sampling frequency for the baseline CNN, including total training time, "
        "process RAM after training, and representative inference latency.\n"
    )
    lines.append(make_markdown_table(cost_df, digits=2))
    lines.append("\n")

    lines.append("### 5.5 CNN Sensitivity and Data Saturation Analyses\n")
    ablation_table = ablation_df.copy()

    for col in ["Train Fraction", "ROC-AUC Macro", "PR-AUC Macro", "Accuracy", "Train Time (s)"]:
        if col in ablation_table.columns:
            ablation_table[col] = ablation_table[col].map(lambda x: f"{x:.3f}" if pd.notnull(x) else "")

    lines.append(
        "Table 5 summarizes CNN sensitivity analyses across kernel sizes, dilation schedules, and training set fractions. "
        "These experiments were performed to assess whether the observed frequency effects were dependent on a single fixed "
        "CNN configuration and to examine whether performance had saturated with the available training data.\n"
    )
    lines.append(ablation_table.to_markdown(index=False))
    lines.append("\n")

    lines.append("### 5.6 Figures\n")
    lines.append(
        "Figure 1 presents the study pipeline from dataset preparation through CNN ablation and evaluation. "
        "Figure 2 shows micro-averaged ROC curves for the baseline CNN at each sampling frequency. "
        "Figure 3 shows micro-averaged precision-recall curves for the baseline CNN. "
        "Figure 4 compares baseline CNN training time across frequencies. "
        "Figure 5 shows baseline CNN learning curves across training set fractions.\n"
    )

    return "\n".join(lines)


def main():
    random.seed(SEED)
    np.random.seed(SEED)
    tf.random.set_seed(SEED)

    DATA_ROOT = kagglehub.dataset_download(DATASET_SLUG)
    print("Downloaded dataset root:", DATA_ROOT)

    META_CSV = find_first(DATA_ROOT, "ptbxl_database.csv")
    SCP_CSV = find_first(DATA_ROOT, "scp_statements.csv")
    if META_CSV is None or SCP_CSV is None:
        raise FileNotFoundError("Could not find ptbxl_database.csv and/or scp_statements.csv in the dataset.")

    DATASET_DIR = maybe_bump_up_for_records(os.path.dirname(META_CSV))
    print("Dataset dir:", DATASET_DIR)
    print("Has records100:", os.path.exists(os.path.join(DATASET_DIR, "records100")))
    print("Has records300:", os.path.exists(os.path.join(DATASET_DIR, "records300")))
    print("Has records500:", os.path.exists(os.path.join(DATASET_DIR, "records500")))

    df = pd.read_csv(META_CSV)
    scp = pd.read_csv(SCP_CSV)

    scp_to_super = build_scp_to_super(df, scp)

    df["scp_codes_dict"] = df["scp_codes"].apply(ensure_dict)
    df["superclasses"] = df["scp_codes_dict"].apply(lambda d: derive_superclasses(d, scp_to_super))

    for s in TARGET_SUPER:
        df[s] = df["superclasses"].apply(lambda ss: 1 if s in ss else 0)

    df = df[df[TARGET_SUPER].sum(axis=1) > 0].reset_index(drop=True)
    print("Total usable ECGs:", len(df))

    dataset_class_counts = df[TARGET_SUPER].sum(axis=0)

    COL_100 = "filename_lr"
    COL_HR = "filename_hr"

    results = {
        "run_info": {
            "time_utc": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "tf_version": tf.__version__,
            "has_gpu": bool(tf.config.list_physical_devices("GPU")),
            "gpus": [d.name for d in tf.config.list_physical_devices("GPU")],
            "seed": SEED,
            "max_samples": MAX_SAMPLES,
            "epochs": EPOCHS,
            "batch_size": BATCH_SIZE,
            "dataset_slug": DATASET_SLUG,
            "dataset_root": DATA_ROOT,
            "dataset_dir": DATASET_DIR,
            "dataset_class_counts": {k: int(v) for k, v in dataset_class_counts.to_dict().items()},
            "cnn_variants": CNN_VARIANTS,
            "train_fractions": TRAIN_FRACTIONS if RUN_LEARNING_CURVES else [1.0],
        },
        "profiles": []
    }

    fractions_to_run = TRAIN_FRACTIONS if RUN_LEARNING_CURVES else [1.0]
    variants_to_run = CNN_VARIANTS if RUN_CNN_ABLATION else [CNN_VARIANTS[0]]

            
    X100, y100, meta100 = load_dataset(df, DATASET_DIR, COL_100, folder_override=None)
    profs100 = run_cnn_ablation(
        X100, y100, "100 Hz (records100)", meta100,
        variants=variants_to_run,
        train_fractions=fractions_to_run,
    )
    results["profiles"].extend(profs100)

            
    X300, y300, meta300 = load_dataset(df, DATASET_DIR, COL_HR, folder_override="records300")
    profs300 = run_cnn_ablation(
        X300, y300, "300 Hz (records300)", meta300,
        variants=variants_to_run,
        train_fractions=fractions_to_run,
    )
    results["profiles"].extend(profs300)

            
    X500, y500, meta500 = load_dataset(df, DATASET_DIR, COL_HR, folder_override=None)
    profs500 = run_cnn_ablation(
        X500, y500, "500 Hz (records500)", meta500,
        variants=variants_to_run,
        train_fractions=fractions_to_run,
    )
    results["profiles"].extend(profs500)

    with open(OUT_JSON, "w", encoding="utf-8") as f:
        json.dump(results, f, indent=2)
    print(f"\nSaved detailed results to: {OUT_JSON}")

    ablation_df = build_cnn_ablation_summary(results)
    ablation_df.to_csv(OUT_ABLATION_CSV, index=False)
    print(f"Saved CNN ablation summary to: {OUT_ABLATION_CSV}")

    fig1 = save_pipeline_placeholder()
    fig2 = save_roc_plot(results)
    fig3 = save_pr_plot(results)
    fig4 = save_training_time_plot(results)
    fig5 = save_learning_curve_plot(results)

    results_text = build_results_section(results, dataset_class_counts)
    with open(OUT_RESULTS_MD, "w", encoding="utf-8") as f:
        f.write(results_text)

    print(f"Saved manuscript-ready results section to: {OUT_RESULTS_MD}")
    print(f"Saved Figure 1 to: {fig1}")
    print(f"Saved Figure 2 to: {fig2}")
    print(f"Saved Figure 3 to: {fig3}")
    print(f"Saved Figure 4 to: {fig4}")
    if fig5 is not None:
        print(f"Saved Figure 5 to: {fig5}")

    print("\n==============================")
    print("MANUSCRIPT RESULTS SECTION")
    print("==============================")
    print(results_text)


if __name__ == "__main__":
    main()
