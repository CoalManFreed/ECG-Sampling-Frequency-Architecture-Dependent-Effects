def find_first(root, filename):
    for r, ds, fs in os.walk(root):
        for f in fs:
            if f == filename:
                return os.path.join(r, f)
    return None

def maybe_bump_up_for_records(dataset_dir):
    needed = ("records100", "records300", "records500")
    if any(os.path.exists(os.path.join(dataset_dir, x)) for x in needed):
        return dataset_dir
    parent = os.path.dirname(dataset_dir)
    if any(os.path.exists(os.path.join(parent, x)) for x in needed):
        return parent
    return dataset_dir

