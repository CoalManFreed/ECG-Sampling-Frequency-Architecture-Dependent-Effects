def save_roc_plot(results):
    plt.figure(figsize=(7, 5))
    for prof in results["profiles"]:
        freq = label_short(prof["label"])
        fpr = prof["curve_data"]["roc_curve"]["fpr"]
        tpr = prof["curve_data"]["roc_curve"]["tpr"]
        auc_val = prof["metrics"]["roc_auc_micro"]
        ci = prof["bootstrap_cis"]["roc_auc_micro"]
        plt.plot(
            fpr, tpr,
            label=f"{freq} (AUC={auc_val:.3f}, 95% CI {ci['ci_lower']:.3f}-{ci['ci_upper']:.3f})"
        )
    plt.plot([0, 1], [0, 1], linestyle="--", color="gray")
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.title("ROC Curves by Sampling Frequency")
    plt.legend(fontsize=8)
    plt.tight_layout()
    out = os.path.join(FIG_DIR, "figure2_roc_curves.png")
    plt.savefig(out, dpi=300, bbox_inches="tight")
    plt.close()
    return out

def save_pr_plot(results):
    plt.figure(figsize=(7, 5))
    for prof in results["profiles"]:
        freq = label_short(prof["label"])
        rec = prof["curve_data"]["pr_curve"]["recall"]
        prec = prof["curve_data"]["pr_curve"]["precision"]
        ap_val = prof["metrics"]["pr_auc_micro"]
        ci = prof["bootstrap_cis"]["pr_auc_micro"]
        plt.plot(
            rec, prec,
            label=f"{freq} (AP={ap_val:.3f}, 95% CI {ci['ci_lower']:.3f}-{ci['ci_upper']:.3f})"
        )
    plt.xlabel("Recall")
    plt.ylabel("Precision")
    plt.title("Precision-Recall Curves by Sampling Frequency")
    plt.legend(fontsize=8)
    plt.tight_layout()
    out = os.path.join(FIG_DIR, "figure3_pr_curves.png")
    plt.savefig(out, dpi=300, bbox_inches="tight")
    plt.close()
    return out

def save_training_time_plot(results):
    freqs = [label_short(p["label"]) for p in results["profiles"]]
    train_times = [p["train_wall_s"] for p in results["profiles"]]

    plt.figure(figsize=(7, 5))
    plt.plot(freqs, train_times, marker="o")
    plt.xlabel("Sampling Frequency")
    plt.ylabel("Training Time (s)")
    plt.title("Training Time vs Sampling Frequency")
    plt.tight_layout()
    out = os.path.join(FIG_DIR, "figure4_training_time_vs_frequency.png")
    plt.savefig(out, dpi=300, bbox_inches="tight")
    plt.close()
    return out


def build_results_section(results, dataset_class_counts):
    lines = []
    lines.append("## 5. Results\n")
    lines.append(
        "This section summarizes dataset composition, Patch Transformer performance across sampling "
        "frequencies, class-specific classification performance, and computational cost. "
        "All performance metrics include 95% bootstrapped confidence intervals (1,000 resamples). "
        "Tables 1-4 and Figures 1-4 present the primary results.\n"
    )

    # 5.1
    lines.append("### 5.1 Dataset Characteristics\n")
    class_df = pd.DataFrame({
        "Class": TARGET_SUPER,
        "Count": [int(dataset_class_counts.get(c, 0)) for c in TARGET_SUPER]
    })
    lines.append(make_markdown_table(class_df, float_cols=[]))
    lines.append("\n")

    # 5.2 — performance table with CIs
    lines.append("### 5.2 Model Performance by Sampling Frequency\n")
    lines.append(
        "Table 2 compares overall Patch Transformer performance across the three sampling frequencies. "
        "Values are point estimates with 95% bootstrapped CIs in parentheses. "
        "Non-overlapping CIs indicate statistically meaningful differences between conditions.\n"
    )
    perf_rows = []
    for prof in results["profiles"]:
        ci_roc = prof["bootstrap_cis"]["roc_auc_macro"]
        ci_pr  = prof["bootstrap_cis"]["pr_auc_macro"]
        ci_acc = prof["bootstrap_cis"]["accuracy"]
        perf_rows.append({
            "Frequency": label_short(prof["label"]),
            "ROC-AUC (95% CI)":  (
                f"{ci_roc['point_estimate']:.3f} "
                f"({ci_roc['ci_lower']:.3f}-{ci_roc['ci_upper']:.3f})"
            ),
            "PR-AUC (95% CI)": (
                f"{ci_pr['point_estimate']:.3f} "
                f"({ci_pr['ci_lower']:.3f}-{ci_pr['ci_upper']:.3f})"
            ),
            "Accuracy (95% CI)": (
                f"{ci_acc['point_estimate']:.3f} "
                f"({ci_acc['ci_lower']:.3f}-{ci_acc['ci_upper']:.3f})"
            ),
        })
    perf_df = pd.DataFrame(perf_rows)
    lines.append(make_markdown_table(perf_df, float_cols=[]))
    lines.append("\n")

    # 5.3 — per-class with CIs
    lines.append("### 5.3 Per-Class Performance\n")
    lines.append(
        "Table 3 shows class-specific ROC-AUC and F1 scores with 95% bootstrapped CIs "
        "for each sampling frequency.\n"
    )
    for prof in results["profiles"]:
        freq = label_short(prof["label"])
        lines.append(f"**{freq}**\n")
        ci_rows = []
        for row in prof["per_class_cis"]:
            ci_rows.append({
                "Class": row["Class"],
                "ROC-AUC (95% CI)": (
                    f"{row['ROC-AUC']:.3f} "
                    f"({row['ROC-AUC CI Lower']:.3f}-{row['ROC-AUC CI Upper']:.3f})"
                ),
                "F1 (95% CI)": (
                    f"{row['F1']:.3f} "
                    f"({row['F1 CI Lower']:.3f}-{row['F1 CI Upper']:.3f})"
                ),
            })
        lines.append(make_markdown_table(pd.DataFrame(ci_rows), float_cols=[]))
        lines.append("\n")

    # 5.4
    lines.append("### 5.4 Computational Cost\n")
    cost_rows = []
    for prof in results["profiles"]:
        inf64 = next((x for x in prof["inference"] if x["batch_size"] == 64), prof["inference"][0])
        gpu_peak = prof["gpu_mem_after"].get("peak_mb", None) if prof["gpu_mem_after"] else None
        cost_rows.append({
            "Frequency": label_short(prof["label"]),
            "Training Time (s)": prof["train_wall_s"],
            "RAM (MB)": prof["rss_mb_after"],
            "Inference (ms/sample)": inf64["ms_per_sample"],
            "GPU Peak (MB)": gpu_peak if gpu_peak is not None else np.nan,
        })
    cost_df = pd.DataFrame(cost_rows)
    lines.append(make_markdown_table(cost_df, digits=2))
    lines.append("\n")

    # 5.5
    lines.append("### 5.5 Figures\n")
    lines.append(
        "Figure 2 shows ROC curves with bootstrapped CI values in the legend. "
        "Figure 3 shows precision-recall curves with CIs. "
        "Figure 4 compares training time across frequencies.\n"
    )

    return "\n".join(lines)

