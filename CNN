def bytes_to_mb(x: float) -> float:
    return float(x) / (1024.0 * 1024.0)


def get_process_rss_mb() -> float:
    proc = psutil.Process(os.getpid())
    return bytes_to_mb(proc.memory_info().rss)


def get_gpu_mem_mb(gpu_index: int = 0) -> Optional[Dict[str, float]]:
    try:
        gpus = tf.config.list_physical_devices("GPU")
        if not gpus or gpu_index >= len(gpus):
            return None
        dev = f"GPU:{gpu_index}"
        info = tf.config.experimental.get_memory_info(dev)
        return {
            "current_mb": bytes_to_mb(info.get("current", 0)),
            "peak_mb": bytes_to_mb(info.get("peak", 0)),
        }
    except Exception:
        return None


def estimate_model_checkpoint_mb(model: tf.keras.Model) -> float:
    return (model.count_params() * 4) / (1024.0 * 1024.0)


def compute_effective_receptive_field(kernels, dilations, pool_size=2):
    """
    Approximate receptive field in input samples for a stack of Conv1D + MaxPool1D layers.
    Assumes stride=1 convolutions and pool stride == pool_size.
    """
    rf = 1
    jump = 1

    for k, d in zip(kernels, dilations):
        effective_kernel = 1 + (k - 1) * d
        rf = rf + (effective_kernel - 1) * jump
        rf = rf + (pool_size - 1) * jump
        jump *= pool_size

    return int(rf)


class EpochTimer(tf.keras.callbacks.Callback):
    def __init__(self):
        super().__init__()
        self.epoch_times = []
        self._t0 = None

    def on_epoch_begin(self, epoch, logs=None):
        self._t0 = time.perf_counter()

    def on_epoch_end(self, epoch, logs=None):
        if self._t0 is None:
            return
        self.epoch_times.append(time.perf_counter() - self._t0)
        self._t0 = None


def find_first(root, filename):
    for r, ds, fs in os.walk(root):
        for f in fs:
            if f == filename:
                return os.path.join(r, f)
    return None


def maybe_bump_up_for_records(dataset_dir):
    needed = ("records100", "records300", "records500")
    if any(os.path.exists(os.path.join(dataset_dir, x)) for x in needed):
        return dataset_dir
    parent = os.path.dirname(dataset_dir)
    if any(os.path.exists(os.path.join(parent, x)) for x in needed):
        return parent
    return dataset_dir


def ensure_dict(x):
    return ast.literal_eval(x) if isinstance(x, str) else x


def build_scp_to_super(df: pd.DataFrame, scp: pd.DataFrame) -> Dict[str, str]:
    df["scp_codes_dict"] = df["scp_codes"].apply(ensure_dict)

    all_keys = set()
    for d in df["scp_codes_dict"].head(5000):
        all_keys.update(d.keys())

    best_col, best_overlap = None, -1
    for c in scp.columns:
        if scp[c].dtype == object:
            overlap = len(set(scp[c].astype(str)) & all_keys)
            if overlap > best_overlap:
                best_overlap = overlap
                best_col = c

    if best_col is None:
        raise RuntimeError("Could not auto-detect SCP code column in scp_statements.csv")

    sub = scp[scp["diagnostic"] == 1][[best_col, "diagnostic_class"]].dropna()
    scp_to_super = {str(code): str(dclass) for code, dclass in sub.itertuples(index=False)}

    print("SCP column detected:", best_col)
    return scp_to_super


def derive_superclasses(d: Dict[str, Any], scp_to_super: Dict[str, str]) -> set:
    return {scp_to_super[c] for c in d if c in scp_to_super}


def load_dataset(df: pd.DataFrame, dataset_dir: str, filename_col: str, folder_override: Optional[str] = None):
    if filename_col not in df.columns:
        filename_cols = [c for c in df.columns if "filename" in c.lower()]
        raise KeyError(f"Missing column '{filename_col}'. Found: {filename_cols}")

    df_use = df.sample(n=min(MAX_SAMPLES, len(df)), random_state=SEED)

    X_list, y_list = [], []
    skipped = 0

    for _, row in df_use.iterrows():
        rel = row[filename_col]
        if not isinstance(rel, str) or rel.strip() == "":
            skipped += 1
            continue

        if folder_override is not None:
            rel = rel.replace("records500", folder_override)

        base = os.path.join(dataset_dir, rel)
        if not os.path.exists(base + ".hea"):
            skipped += 1
            continue

        sig, _ = wfdb.rdsamp(base)
        X_list.append(sig.astype(np.float32))
        y_list.append(row[TARGET_SUPER].values.astype(np.float32))

    if len(X_list) == 0:
        raise RuntimeError(
            f"Loaded 0 records for {filename_col} override={folder_override}. "
            f"Check dataset_dir={dataset_dir}"
        )

    lengths = [x.shape[0] for x in X_list]
    L = int(np.median(lengths))
    C = int(X_list[0].shape[1])

    def pad_or_crop(x):
        if x.shape[0] > L:
            start = (x.shape[0] - L) // 2
            return x[start:start + L]
        return np.pad(x, ((0, L - x.shape[0]), (0, 0)))

    X = np.stack([pad_or_crop(x) for x in X_list])
    y = np.stack(y_list)

    X = (X - X.mean(axis=1, keepdims=True)) / (X.std(axis=1, keepdims=True) + 1e-6)

    meta = {
        "n_loaded": int(len(X)),
        "n_skipped": int(skipped),
        "L": int(L),
        "C": int(C),
        "filename_col": filename_col,
        "folder_override": folder_override,
    }
    print(
        f"Loaded {meta['n_loaded']} | skipped {meta['n_skipped']} | "
        f"L={L} | C={C} | col={filename_col} | override={folder_override}"
    )
    return X, y, meta


def make_model(
    input_shape,
    filters=(32, 64, 128),
    kernels=(7, 5, 3),
    dilations=(1, 1, 1),
    dense_units=None,
    dropout_rate=0.0,
    name="cnn_model",
):
    if not (len(filters) == len(kernels) == len(dilations)):
        raise ValueError("filters, kernels, and dilations must have the same length")

    inp = layers.Input(shape=input_shape)
    x = inp

    for i, (f, k, d) in enumerate(zip(filters, kernels, dilations)):
        x = layers.Conv1D(
            filters=f,
            kernel_size=k,
            dilation_rate=d,
            padding="same",
            activation="relu",
            name=f"conv_{i+1}",
        )(x)
        x = layers.MaxPool1D(2, name=f"pool_{i+1}")(x)

    x = layers.GlobalAveragePooling1D(name="gap")(x)

    if dense_units is not None:
        x = layers.Dense(dense_units, activation="relu", name="dense_hidden")(x)
        if dropout_rate > 0:
            x = layers.Dropout(dropout_rate, name="dropout")(x)

    out = layers.Dense(len(TARGET_SUPER), activation="sigmoid", name="output")(x)
    return models.Model(inp, out, name=name)


@dataclass
class InferenceStats:
    batch_size: int
    n_samples: int
    wall_s: float
    ms_per_sample: float
    samples_per_s: float
    rss_mb_before: float
    rss_mb_after: float
    gpu_mem_before: Optional[Dict[str, float]]
    gpu_mem_after: Optional[Dict[str, float]]


def measure_inference(model, X):
    out = []
    for bs in INF_BATCH_SIZES:
        n_total = min(len(X), bs * INF_N_BATCHES)
        Xb = X[:n_total]

        for _ in range(INF_WARMUP_BATCHES):
            _ = model.predict(Xb[: min(bs, n_total)], batch_size=bs, verbose=0)

        rss_before = get_process_rss_mb()
        gpu_before = get_gpu_mem_mb(GPU_INDEX)

        t0 = time.perf_counter()
        _ = model.predict(Xb, batch_size=bs, verbose=0)
        wall = time.perf_counter() - t0

        rss_after = get_process_rss_mb()
        gpu_after = get_gpu_mem_mb(GPU_INDEX)

        ms_per_sample = (wall * 1000.0) / max(1, n_total)
        sps = n_total / max(1e-9, wall)

        out.append(InferenceStats(
            batch_size=int(bs),
            n_samples=int(n_total),
            wall_s=float(wall),
            ms_per_sample=float(ms_per_sample),
            samples_per_s=float(sps),
            rss_mb_before=float(rss_before),
            rss_mb_after=float(rss_after),
            gpu_mem_before=gpu_before,
            gpu_mem_after=gpu_after,
        ))
    return out


def compute_per_class_metrics(y_true, y_prob, threshold=0.5):
    y_pred = (y_prob >= threshold).astype(int)
    precision, recall, f1, support = precision_recall_fscore_support(
        y_true, y_pred, average=None, zero_division=0
    )

    rows = []
    for i, cls in enumerate(TARGET_SUPER):
        rows.append({
            "Class": cls,
            "Precision": float(precision[i]),
            "Recall": float(recall[i]),
            "F1": float(f1[i]),
            "Support": int(support[i]),
        })
    return rows


def compute_curve_data(y_true, y_prob):
    y_true_flat = y_true.ravel()
    y_prob_flat = y_prob.ravel()

    fpr, tpr, _ = roc_curve(y_true_flat, y_prob_flat)
    prec, rec, _ = precision_recall_curve(y_true_flat, y_prob_flat)

    return {
        "roc_curve": {
            "fpr": fpr.tolist(),
            "tpr": tpr.tolist(),
        },
        "pr_curve": {
            "precision": prec.tolist(),
            "recall": rec.tolist(),
        }
    }


def bootstrap_ci(
    y_true,
    y_prob,
    metric_fn,
    n_bootstrap=N_BOOTSTRAP,
    ci_alpha=CI_ALPHA,
    seed=BOOTSTRAP_SEED
):
    rng = np.random.default_rng(seed)
    n = len(y_true)
    scores = []

    for _ in range(n_bootstrap):
        idx = rng.integers(0, n, size=n)
        try:
            score = metric_fn(y_true[idx], y_prob[idx])
            scores.append(score)
        except ValueError:
            continue

    point_estimate = float(metric_fn(y_true, y_prob))

    if len(scores) == 0:
        return {
            "point_estimate": point_estimate,
            "ci_lower": float("nan"),
            "ci_upper": float("nan"),
            "ci_alpha": ci_alpha,
            "n_bootstrap": 0,
        }

    scores = np.array(scores)
    lower_p = (1.0 - ci_alpha) / 2.0 * 100.0
    upper_p = (1.0 - (1.0 - ci_alpha) / 2.0) * 100.0

    return {
        "point_estimate": point_estimate,
        "ci_lower": float(np.percentile(scores, lower_p)),
        "ci_upper": float(np.percentile(scores, upper_p)),
        "ci_alpha": ci_alpha,
        "n_bootstrap": int(len(scores)),
    }


def compute_all_bootstrap_cis(y_true, y_prob):
    def roc_macro(yt, yp):
        return roc_auc_score(yt, yp, average="macro")

    def roc_micro(yt, yp):
        return roc_auc_score(yt, yp, average="micro")

    def pr_macro(yt, yp):
        return average_precision_score(yt, yp, average="macro")

    def pr_micro(yt, yp):
        return average_precision_score(yt, yp, average="micro")

    def exact_match_acc(yt, yp):
        y_pred = (yp >= 0.5).astype(int)
        return float(np.mean(np.all(y_pred == yt.astype(int), axis=1)))

    ci_results = {
        "roc_auc_macro": bootstrap_ci(y_true, y_prob, roc_macro),
        "roc_auc_micro": bootstrap_ci(y_true, y_prob, roc_micro),
        "pr_auc_macro": bootstrap_ci(y_true, y_prob, pr_macro),
        "pr_auc_micro": bootstrap_ci(y_true, y_prob, pr_micro),
        "accuracy": bootstrap_ci(y_true, y_prob, exact_match_acc),
    }

    print("\n--- Bootstrapped 95% CIs ---")
    for metric, vals in ci_results.items():
        print(
            f"{metric}: {vals['point_estimate']:.4f} "
            f"(95% CI {vals['ci_lower']:.4f}-{vals['ci_upper']:.4f}) "
            f"[n={vals['n_bootstrap']}]"
        )

    return ci_results


def compute_per_class_bootstrap_cis(y_true, y_prob, threshold=0.5):
    rows = []

    for i, cls in enumerate(TARGET_SUPER):
        def roc_cls(yt, yp, idx=i):
            if len(np.unique(yt[:, idx])) < 2:
                raise ValueError("Only one class present")
            return roc_auc_score(yt[:, idx], yp[:, idx])

        def f1_cls(yt, yp, idx=i):
            y_pred = (yp[:, idx] >= threshold).astype(int)
            _, _, f1, _ = precision_recall_fscore_support(
                yt[:, idx], y_pred, average="binary", zero_division=0
            )
            return float(f1)

        roc_ci = bootstrap_ci(y_true, y_prob, roc_cls, seed=BOOTSTRAP_SEED + i)
        f1_ci = bootstrap_ci(y_true, y_prob, f1_cls, seed=BOOTSTRAP_SEED + 100 + i)

        rows.append({
            "Class": cls,
            "ROC-AUC": roc_ci["point_estimate"],
            "ROC-AUC CI Lower": roc_ci["ci_lower"],
            "ROC-AUC CI Upper": roc_ci["ci_upper"],
            "F1": f1_ci["point_estimate"],
            "F1 CI Lower": f1_ci["ci_lower"],
            "F1 CI Upper": f1_ci["ci_upper"],
        })

    return rows


def train_and_profile(X, y, label, data_meta, model_config=None, train_fraction=1.0):
    print("\n==============================")
    print(f"Training on {label}")
    print("==============================")

    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.2, random_state=SEED,
        stratify=np.argmax(y, axis=1)
    )
    X_train, X_val, y_train, y_val = train_test_split(
        X_train, y_train, test_size=0.2, random_state=SEED,
        stratify=np.argmax(y_train, axis=1)
    )

    if train_fraction < 1.0:
        n_sub = max(1, int(len(X_train) * train_fraction))
        rng = np.random.default_rng(SEED)
        idx = rng.choice(len(X_train), size=n_sub, replace=False)
        X_train = X_train[idx]
        y_train = y_train[idx]

    if model_config is None:
        model_config = {
            "name": "baseline",
            "filters": [32, 64, 128],
            "kernels": [7, 5, 3],
            "dilations": [1, 1, 1],
        }

    model = make_model(
        input_shape=(X.shape[1], X.shape[2]),
        filters=model_config["filters"],
        kernels=model_config["kernels"],
        dilations=model_config["dilations"],
        name=model_config["name"],
    )
    model.compile(
        optimizer=optimizers.Adam(1e-3),
        loss="binary_crossentropy",
        metrics=[tf.keras.metrics.AUC(curve="ROC", multi_label=True, name="auc_roc")]
    )

    timer = EpochTimer()
    rss_before = get_process_rss_mb()
    gpu_before = get_gpu_mem_mb(GPU_INDEX)

    t0 = time.perf_counter()
    model.fit(
        X_train, y_train,
        validation_data=(X_val, y_val),
        epochs=EPOCHS,
        batch_size=BATCH_SIZE,
        verbose=1,
        callbacks=[timer]
    )
    train_wall = time.perf_counter() - t0

    rss_after = get_process_rss_mb()
    gpu_after = get_gpu_mem_mb(GPU_INDEX)

    y_prob = model.predict(X_test, batch_size=BATCH_SIZE, verbose=0)
    y_pred = (y_prob >= 0.5).astype(int)

    subset_accuracy = float(np.mean(np.all(y_pred == y_test.astype(int), axis=1)))

    metrics = {
        "roc_auc_micro": float(roc_auc_score(y_test, y_prob, average="micro")),
        "roc_auc_macro": float(roc_auc_score(y_test, y_prob, average="macro")),
        "pr_auc_micro": float(average_precision_score(y_test, y_prob, average="micro")),
        "pr_auc_macro": float(average_precision_score(y_test, y_prob, average="macro")),
        "accuracy": subset_accuracy,
    }

    bootstrap_cis = compute_all_bootstrap_cis(y_test, y_prob)
    per_class_metrics = compute_per_class_metrics(y_test, y_prob, threshold=0.5)
    per_class_bootstrap_cis = compute_per_class_bootstrap_cis(y_test, y_prob, threshold=0.5)
    curve_data = compute_curve_data(y_test, y_prob)
    inf = measure_inference(model, X_test)

    epoch_times = timer.epoch_times
    epoch_mean = float(np.mean(epoch_times)) if epoch_times else float("nan")
    epoch_median = float(np.median(epoch_times)) if epoch_times else float("nan")

    profile = {
        "label": label,
        "model_name": model_config["name"],
        "model_config": model_config,
        "train_fraction": float(train_fraction),
        "effective_receptive_field_samples": int(
            compute_effective_receptive_field(
                model_config["kernels"],
                model_config["dilations"]
            )
        ),
        "n_train": int(len(X_train)),
        "n_val": int(len(X_val)),
        "n_test": int(len(X_test)),
        "epochs": int(EPOCHS),
        "batch_size": int(BATCH_SIZE),
        "train_wall_s": float(train_wall),
        "epoch_times_s": [float(x) for x in epoch_times],
        "epoch_time_mean_s": epoch_mean,
        "epoch_time_median_s": epoch_median,
        "rss_mb_before": float(rss_before),
        "rss_mb_after": float(rss_after),
        "gpu_mem_before": gpu_before,
        "gpu_mem_after": gpu_after,
        "n_params": int(model.count_params()),
        "est_checkpoint_mb": float(estimate_model_checkpoint_mb(model)),
        "metrics": metrics,
        "bootstrap_cis": bootstrap_cis,
        "per_class_metrics": per_class_metrics,
        "per_class_bootstrap_cis": per_class_bootstrap_cis,
        "curve_data": curve_data,
        "inference": [asdict(x) for x in inf],
        "data_meta": data_meta,
    }
    return model, profile


def run_cnn_ablation(X, y, base_label, data_meta, variants, train_fractions=None):
    all_profiles = []

    if train_fractions is None:
        train_fractions = [1.0]

    for variant in variants:
        for frac in train_fractions:
            run_label = f"{base_label} | CNN={variant['name']} | train_fraction={frac:.1f}"
            _, prof = train_and_profile(
                X,
                y,
                run_label,
                data_meta,
                model_config=variant,
                train_fraction=frac,
            )
            all_profiles.append(prof)

    return all_profiles


def label_short(label: str) -> str:
    if "100" in label:
        return "100 Hz"
    if "300" in label:
        return "300 Hz"
    if "500" in label:
        return "500 Hz"
    return label


def get_primary_profiles(results):
    """
    Use baseline CNN at full training fraction for main manuscript figures/tables,
    while keeping the full ablation set in the JSON/CSV outputs.
    """
    primary = [
        p for p in results["profiles"]
        if p.get("model_name") == "baseline" and abs(p.get("train_fraction", 1.0) - 1.0) < 1e-9
    ]

    def sort_key(p):
        lab = p["label"]
        if "100" in lab:
            return 100
        if "300" in lab:
            return 300
        if "500" in lab:
            return 500
        return 999

    return sorted(primary, key=sort_key)


def make_markdown_table(df: pd.DataFrame, float_cols: Optional[List[str]] = None, digits: int = 3) -> str:
    df_fmt = df.copy()
    if float_cols is None:
        float_cols = list(df_fmt.select_dtypes(include=[np.number]).columns)

    for col in float_cols:
        if col in df_fmt.columns:
            df_fmt[col] = df_fmt[col].map(lambda x: f"{x:.{digits}f}" if pd.notnull(x) else "")

    return df_fmt.to_markdown(index=False)


def save_roc_plot(results):
    primary_profiles = get_primary_profiles(results)

    plt.figure(figsize=(7, 5))
    for prof in primary_profiles:
        freq = label_short(prof["label"])
        fpr = prof["curve_data"]["roc_curve"]["fpr"]
        tpr = prof["curve_data"]["roc_curve"]["tpr"]
        auc_val = prof["metrics"]["roc_auc_micro"]
        ci = prof["bootstrap_cis"]["roc_auc_micro"]

        plt.plot(
            fpr,
            tpr,
            label=f"{freq} (AUC={auc_val:.3f}, 95% CI {ci['ci_lower']:.3f}-{ci['ci_upper']:.3f})"
        )

    plt.plot([0, 1], [0, 1], linestyle="--")
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.title("ROC Curves by Sampling Frequency (Baseline CNN, Full Data)")
    plt.legend(fontsize=8)
    plt.tight_layout()
    out = os.path.join(FIG_DIR, "figure2_roc_curves.png")
    plt.savefig(out, dpi=300, bbox_inches="tight")
    plt.close()
    return out


def save_pr_plot(results):
    primary_profiles = get_primary_profiles(results)

    plt.figure(figsize=(7, 5))
    for prof in primary_profiles:
        freq = label_short(prof["label"])
        rec = prof["curve_data"]["pr_curve"]["recall"]
        prec = prof["curve_data"]["pr_curve"]["precision"]
        ap_val = prof["metrics"]["pr_auc_micro"]
        ci = prof["bootstrap_cis"]["pr_auc_micro"]

        plt.plot(
            rec,
            prec,
            label=f"{freq} (AP={ap_val:.3f}, 95% CI {ci['ci_lower']:.3f}-{ci['ci_upper']:.3f})"
        )

    plt.xlabel("Recall")
    plt.ylabel("Precision")
    plt.title("Precision-Recall Curves by Sampling Frequency (Baseline CNN, Full Data)")
    plt.legend(fontsize=8)
    plt.tight_layout()
    out = os.path.join(FIG_DIR, "figure3_pr_curves.png")
    plt.savefig(out, dpi=300, bbox_inches="tight")
    plt.close()
    return out


