def build_results_section(results, dataset_class_counts: pd.Series):
    lines = []
    lines.append("## 5. Results\n")
    lines.append(
        "This section summarizes dataset composition, model discrimination across sampling frequencies, "
        "per-class classification performance, and computational cost. Overall performance metrics include "
        f"95% bootstrapped confidence intervals ({N_BOOTSTRAP} resamples). Tables 1-4 and Figures 1-4 present the primary findings.\n"
    )

    # 5.1 Dataset Characteristics
    lines.append("### 5.1 Dataset Characteristics\n")
    class_df = pd.DataFrame({
        "Class": TARGET_SUPER,
        "Count": [int(dataset_class_counts.get(c, 0)) for c in TARGET_SUPER]
    })
    lines.append("Table 1 summarizes the number of ECGs assigned to each diagnostic superclass in the filtered PTB-XL cohort used for model development.\n")
    lines.append(make_markdown_table(class_df, float_cols=[]))
    lines.append("\n")

    # 5.2 Model Performance by Sampling Frequency
    lines.append("### 5.2 Model Performance by Sampling Frequency\n")
    perf_rows = []
    for prof in results["profiles"]:
        roc_ci = prof["bootstrap_cis"]["roc_auc_macro"]
        pr_ci = prof["bootstrap_cis"]["pr_auc_macro"]
        acc_ci = prof["bootstrap_cis"]["accuracy"]

        perf_rows.append({
            "Frequency": label_short(prof["label"]),
            "ROC-AUC (95% CI)": f"{prof['metrics']['roc_auc_macro']:.3f} ({roc_ci['ci_lower']:.3f}-{roc_ci['ci_upper']:.3f})",
            "PR-AUC (95% CI)": f"{prof['metrics']['pr_auc_macro']:.3f} ({pr_ci['ci_lower']:.3f}-{pr_ci['ci_upper']:.3f})",
            "Accuracy (95% CI)": f"{prof['metrics']['accuracy']:.3f} ({acc_ci['ci_lower']:.3f}-{acc_ci['ci_upper']:.3f})",
        })
    perf_df = pd.DataFrame(perf_rows)
    lines.append(
        "Table 2 compares overall classification performance across the three sampling frequencies. "
        "ROC-AUC and PR-AUC are reported as macro-averaged values, and accuracy is reported as exact-match "
        "multilabel accuracy. Values in parentheses are 95% bootstrapped confidence intervals.\n"
    )
    lines.append(perf_df.to_markdown(index=False))
    lines.append("\n")

    # 5.3 Per-Class Performance
    lines.append("### 5.3 Per-Class Performance\n")
    lines.append(
        "Table 3 shows class-specific precision, recall, F1 score, and per-class ROC-AUC for each sampling "
        "frequency. Bootstrapped 95% confidence intervals are provided for per-class ROC-AUC and F1.\n"
    )

    for prof in results["profiles"]:
        freq = label_short(prof["label"])

        perf_df = pd.DataFrame(prof["per_class_metrics"]).rename(columns={"F1": "F1_point"})
        ci_df = pd.DataFrame(prof["per_class_bootstrap_cis"]).rename(columns={"F1": "F1_ci_point"})

        merged = perf_df.merge(ci_df, on="Class", how="left")

        merged["F1 (95% CI)"] = merged.apply(
            lambda r: f"{r['F1_point']:.3f} ({r['F1 CI Lower']:.3f}-{r['F1 CI Upper']:.3f})",
            axis=1
        )
        merged["ROC-AUC (95% CI)"] = merged.apply(
            lambda r: f"{r['ROC-AUC']:.3f} ({r['ROC-AUC CI Lower']:.3f}-{r['ROC-AUC CI Upper']:.3f})",
            axis=1
        )

        show_df = merged[["Class", "Precision", "Recall", "F1 (95% CI)", "ROC-AUC (95% CI)"]].copy()
        show_df["Precision"] = show_df["Precision"].map(lambda x: f"{x:.3f}")
        show_df["Recall"] = show_df["Recall"].map(lambda x: f"{x:.3f}")

        lines.append(f"**{freq}**\n")
        lines.append(show_df.to_markdown(index=False))
        lines.append("\n")

    # 5.4 Computational Cost
    lines.append("### 5.4 Computational Cost\n")
    cost_rows = []
    for prof in results["profiles"]:
        inf64 = None
        for item in prof["inference"]:
            if item["batch_size"] == 64:
                inf64 = item
                break
        if inf64 is None:
            inf64 = prof["inference"][0]

        gpu_peak = None
        if prof["gpu_mem_after"] is not None:
            gpu_peak = prof["gpu_mem_after"].get("peak_mb", None)

        cost_rows.append({
            "Frequency": label_short(prof["label"]),
            "Training Time (s)": prof["train_wall_s"],
            "RAM (MB)": prof["rss_mb_after"],
            "Inference (ms/sample)": inf64["ms_per_sample"],
            "GPU Peak (MB)": gpu_peak if gpu_peak is not None else np.nan,
        })

    cost_df = pd.DataFrame(cost_rows)
    lines.append("Table 4 reports computational cost by sampling frequency, including total training time, process RAM after training, and representative inference latency.\n")
    lines.append(make_markdown_table(cost_df, digits=2))
    lines.append("\n")

    # 5.5 Figures
    lines.append("### 5.5 Figures\n")
    lines.append(
        "Figure 1 presents the study pipeline from dataset preparation through model training and evaluation. "
        "Figure 2 shows micro-averaged ROC curves for each sampling frequency with 95% bootstrapped confidence "
        "intervals reported in the legend. Figure 3 shows micro-averaged precision-recall curves with 95% "
        "bootstrapped confidence intervals reported in the legend. Figure 4 compares training time across frequencies.\n"
    )

    return "\n".join(lines)


