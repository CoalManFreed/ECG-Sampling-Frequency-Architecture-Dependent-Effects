def bytes_to_mb(x: float) -> float:
    return float(x) / (1024.0 * 1024.0)


def get_process_rss_mb() -> float:
    proc = psutil.Process(os.getpid())
    return bytes_to_mb(proc.memory_info().rss)


def get_gpu_mem_mb(gpu_index: int = 0) -> Optional[Dict[str, float]]:
    try:
        gpus = tf.config.list_physical_devices("GPU")
        if not gpus or gpu_index >= len(gpus):
            return None
        dev = f"GPU:{gpu_index}"
        info = tf.config.experimental.get_memory_info(dev)
        return {
            "current_mb": bytes_to_mb(info.get("current", 0)),
            "peak_mb": bytes_to_mb(info.get("peak", 0)),
        }
    except Exception:
        return None


def estimate_model_checkpoint_mb(model: tf.keras.Model) -> float:
    return (model.count_params() * 4) / (1024.0 * 1024.0)


def compute_effective_receptive_field(kernels, dilations, pool_size=2):
    rf = 1
    jump = 1

    for k, d in zip(kernels, dilations):
        effective_kernel = 1 + (k - 1) * d
        rf = rf + (effective_kernel - 1) * jump
        rf = rf + (pool_size - 1) * jump
        jump *= pool_size

    return int(rf)


class EpochTimer(tf.keras.callbacks.Callback):
    def __init__(self):
        super().__init__()
        self.epoch_times = []
        self._t0 = None

    def on_epoch_begin(self, epoch, logs=None):
        self._t0 = time.perf_counter()

    def on_epoch_end(self, epoch, logs=None):
        if self._t0 is None:
            return
        self.epoch_times.append(time.perf_counter() - self._t0)
        self._t0 = None


def find_first(root, filename):
    for r, ds, fs in os.walk(root):
        for f in fs:
            if f == filename:
                return os.path.join(r, f)
    return None


def maybe_bump_up_for_records(dataset_dir):
    needed = ("records100", "records300", "records500")
    if any(os.path.exists(os.path.join(dataset_dir, x)) for x in needed):
        return dataset_dir
    parent = os.path.dirname(dataset_dir)
    if any(os.path.exists(os.path.join(parent, x)) for x in needed):
        return parent
    return dataset_dir


def ensure_dict(x):
    return ast.literal_eval(x) if isinstance(x, str) else x


def build_scp_to_super(df: pd.DataFrame, scp: pd.DataFrame) -> Dict[str, str]:
    df["scp_codes_dict"] = df["scp_codes"].apply(ensure_dict)

    all_keys = set()
    for d in df["scp_codes_dict"].head(5000):
        all_keys.update(d.keys())

    best_col, best_overlap = None, -1
    for c in scp.columns:
        if scp[c].dtype == object:
            overlap = len(set(scp[c].astype(str)) & all_keys)
            if overlap > best_overlap:
                best_overlap = overlap
                best_col = c

    if best_col is None:
        raise RuntimeError("Could not auto-detect SCP code column in scp_statements.csv")

    sub = scp[scp["diagnostic"] == 1][[best_col, "diagnostic_class"]].dropna()
    scp_to_super = {str(code): str(dclass) for code, dclass in sub.itertuples(index=False)}

    print("SCP column detected:", best_col)
    return scp_to_super


def derive_superclasses(d: Dict[str, Any], scp_to_super: Dict[str, str]) -> set:
    return {scp_to_super[c] for c in d if c in scp_to_super}


def load_dataset(df: pd.DataFrame, dataset_dir: str, filename_col: str, folder_override: Optional[str] = None):
    if filename_col not in df.columns:
        filename_cols = [c for c in df.columns if "filename" in c.lower()]
        raise KeyError(f"Missing column '{filename_col}'. Found: {filename_cols}")

    df_use = df.sample(n=min(MAX_SAMPLES, len(df)), random_state=SEED)

    X_list, y_list = [], []
    skipped = 0

    for _, row in df_use.iterrows():
        rel = row[filename_col]
        if not isinstance(rel, str) or rel.strip() == "":
            skipped += 1
            continue

        if folder_override is not None:
            rel = rel.replace("records500", folder_override)

        base = os.path.join(dataset_dir, rel)
        if not os.path.exists(base + ".hea"):
            skipped += 1
            continue

        sig, _ = wfdb.rdsamp(base)
        X_list.append(sig.astype(np.float32))
        y_list.append(row[TARGET_SUPER].values.astype(np.float32))

    if len(X_list) == 0:
        raise RuntimeError(
            f"Loaded 0 records for {filename_col} override={folder_override}. "
            f"Check dataset_dir={dataset_dir}"
        )

    lengths = [x.shape[0] for x in X_list]
    L = int(np.median(lengths))
    C = int(X_list[0].shape[1])

    def pad_or_crop(x):
        if x.shape[0] > L:
            start = (x.shape[0] - L) // 2
            return x[start:start + L]
        return np.pad(x, ((0, L - x.shape[0]), (0, 0)))

    X = np.stack([pad_or_crop(x) for x in X_list])
    y = np.stack(y_list)

    X = (X - X.mean(axis=1, keepdims=True)) / (X.std(axis=1, keepdims=True) + 1e-6)

    meta = {
        "n_loaded": int(len(X)),
        "n_skipped": int(skipped),
        "L": int(L),
        "C": int(C),
        "filename_col": filename_col,
        "folder_override": folder_override,
    }
    print(
        f"Loaded {meta['n_loaded']} | skipped {meta['n_skipped']} | "
        f"L={L} | C={C} | col={filename_col} | override={folder_override}"
    )
    return X, y, meta
