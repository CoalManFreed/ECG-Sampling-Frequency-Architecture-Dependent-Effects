def make_markdown_table(df: pd.DataFrame, float_cols=None, digits: int = 3) -> str:
    df_fmt = df.copy()
    if float_cols is None:
        float_cols = list(df_fmt.select_dtypes(include=[np.number]).columns)
    for col in float_cols:
        if col in df_fmt.columns:
            df_fmt[col] = df_fmt[col].map(lambda x: f"{x:.{digits}f}" if pd.notnull(x) else "")
    return df_fmt.to_markdown(index=False)

def bootstrap_ci(y_true, y_prob, metric_fn, n_bootstrap=N_BOOTSTRAP,
                 ci_alpha=CI_ALPHA, seed=BOOTSTRAP_SEED):

    rng = np.random.default_rng(seed)
    n = len(y_true)
    scores = []

    for _ in range(n_bootstrap):
        idx = rng.integers(0, n, size=n)          # sample with replacement
        try:
            score = metric_fn(y_true[idx], y_prob[idx])
            scores.append(score)
        except ValueError:
            # can happen if a resample lacks a class — skip silently
            continue

    scores = np.array(scores)
    lower_p = (1.0 - ci_alpha) / 2.0 * 100
    upper_p = (1.0 - (1.0 - ci_alpha) / 2.0) * 100

    return {
        "point_estimate": float(metric_fn(y_true, y_prob)),
        "ci_lower": float(np.percentile(scores, lower_p)),
        "ci_upper": float(np.percentile(scores, upper_p)),
        "ci_alpha": ci_alpha,
        "n_bootstrap": len(scores),
    }


def compute_all_bootstrap_cis(y_true, y_prob):

    print(f"\nComputing bootstrapped CIs ({N_BOOTSTRAP} resamples) ...")

    def roc_macro(yt, yp):
        return roc_auc_score(yt, yp, average="macro")

    def roc_micro(yt, yp):
        return roc_auc_score(yt, yp, average="micro")

    def pr_macro(yt, yp):
        return average_precision_score(yt, yp, average="macro")

    def pr_micro(yt, yp):
        return average_precision_score(yt, yp, average="micro")

    def exact_match_acc(yt, yp):
        y_pred = (yp >= 0.5).astype(int)
        return float(np.mean(np.all(y_pred == yt.astype(int), axis=1)))

    ci_results = {
        "roc_auc_macro": bootstrap_ci(y_true, y_prob, roc_macro),
        "roc_auc_micro": bootstrap_ci(y_true, y_prob, roc_micro),
        "pr_auc_macro":  bootstrap_ci(y_true, y_prob, pr_macro),
        "pr_auc_micro":  bootstrap_ci(y_true, y_prob, pr_micro),
        "accuracy":      bootstrap_ci(y_true, y_prob, exact_match_acc),
    }

    print("\n--- Bootstrapped 95% CIs ---")
    for metric, vals in ci_results.items():
        print(
            f"  {metric:<20s}: {vals['point_estimate']:.4f} "
            f"(95% CI {vals['ci_lower']:.4f} - {vals['ci_upper']:.4f})"
            f"  [n={vals['n_bootstrap']}]"
        )

    return ci_results


def compute_per_class_bootstrap_cis(y_true, y_prob):

    print("\nComputing per-class bootstrapped CIs ...")

    per_class = []
    for i, cls in enumerate(TARGET_SUPER):
        def roc_cls(yt, yp, idx=i):
            if len(np.unique(yt[:, idx])) < 2:
                raise ValueError("Only one class present")
            return roc_auc_score(yt[:, idx], yp[:, idx])

        def f1_cls(yt, yp, idx=i):
            y_pred = (yp[:, idx] >= 0.5).astype(int)
            _, _, f1, _ = precision_recall_fscore_support(
                yt[:, idx], y_pred, average="binary", zero_division=0
            )
            return float(f1)

        # Use offset seeds per class so resamples are independent across classes
        roc_ci = bootstrap_ci(y_true, y_prob, roc_cls, seed=BOOTSTRAP_SEED + i)
        f1_ci  = bootstrap_ci(y_true, y_prob, f1_cls,  seed=BOOTSTRAP_SEED + 10 + i)

        per_class.append({
            "Class": cls,
            "ROC-AUC": roc_ci["point_estimate"],
            "ROC-AUC CI Lower": roc_ci["ci_lower"],
            "ROC-AUC CI Upper": roc_ci["ci_upper"],
            "F1": f1_ci["point_estimate"],
            "F1 CI Lower": f1_ci["ci_lower"],
            "F1 CI Upper": f1_ci["ci_upper"],
        })

        print(
            f"  {cls}: ROC-AUC {roc_ci['point_estimate']:.4f} "
            f"(95% CI {roc_ci['ci_lower']:.4f}-{roc_ci['ci_upper']:.4f}) | "
            f"F1 {f1_ci['point_estimate']:.4f} "
            f"(95% CI {f1_ci['ci_lower']:.4f}-{f1_ci['ci_upper']:.4f})"
        )

    return per_class


