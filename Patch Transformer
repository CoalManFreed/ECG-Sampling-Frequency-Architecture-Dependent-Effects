def load_dataset(filename_col, folder_override=None):
    if filename_col not in df.columns:
        raise KeyError(
            f"Missing column '{filename_col}'. Found: {[c for c in df.columns if 'filename' in c.lower()]}"
        )

    df_use = df.sample(n=min(MAX_SAMPLES, len(df)), random_state=SEED)

    X_list, y_list = [], []
    skipped = 0

    for _, row in df_use.iterrows():
        rel = row[filename_col]
        if not isinstance(rel, str) or rel.strip() == "":
            skipped += 1
            continue

        if folder_override is not None:
            rel = rel.replace("records500", folder_override)

        base = os.path.join(DATASET_DIR, rel)
        if not os.path.exists(base + ".hea"):
            skipped += 1
            continue

        sig, _ = wfdb.rdsamp(base)
        X_list.append(sig.astype(np.float32))
        y_list.append(row[TARGET_SUPER].values.astype(np.float32))

    if len(X_list) == 0:
        raise RuntimeError(
            f"Loaded 0 records for {filename_col} (override={folder_override}). "
            f"Check DATASET_DIR={DATASET_DIR} and folder existence."
        )

    lengths = [x.shape[0] for x in X_list]
    L = int(np.median(lengths))
    C = X_list[0].shape[1]

    def pad_or_crop(x):
        if x.shape[0] > L:
            start = (x.shape[0] - L)//2
            return x[start:start+L]
        return np.pad(x, ((0, L-x.shape[0]), (0,0)))

    X = np.stack([pad_or_crop(x) for x in X_list])
    y = np.stack(y_list)

    X = (X - X.mean(axis=1, keepdims=True)) / (X.std(axis=1, keepdims=True) + 1e-6)

    meta = {
        "n_loaded": int(len(X)),
        "n_skipped": int(skipped),
        "L": int(L),
        "C": int(C),
        "filename_col": filename_col,
        "folder_override": folder_override,
    }

    print(f"Loaded {len(X)} | skipped {skipped} | L={L} | C={C} | col={filename_col} | override={folder_override}")
    return X, y, meta


def pick_patch_and_batch(seq_len):
    if seq_len <= 1500:
        return PATCH_SIZE_100, BATCH_SIZE_100
    elif seq_len <= 3800:
        return PATCH_SIZE_300, BATCH_SIZE_300
    else:
        return PATCH_SIZE_500, BATCH_SIZE_500

class TransformerBlock(layers.Layer):
    def __init__(self, d_model, num_heads, ff_dim, dropout=0.1, **kwargs):
        super().__init__(**kwargs)
        key_dim = max(1, d_model // num_heads)
        self.att = layers.MultiHeadAttention(num_heads=num_heads, key_dim=key_dim)
        self.ffn = models.Sequential([
            layers.Dense(ff_dim, activation="relu"),
            layers.Dense(d_model),
        ])
        self.norm1 = layers.LayerNormalization(epsilon=1e-6)
        self.norm2 = layers.LayerNormalization(epsilon=1e-6)
        self.drop1 = layers.Dropout(dropout)
        self.drop2 = layers.Dropout(dropout)

    def call(self, x, training=False):
        attn = self.att(x, x, training=training)
        attn = self.drop1(attn, training=training)
        x = self.norm1(x + attn)
        ffn = self.ffn(x, training=training)
        ffn = self.drop2(ffn, training=training)
        return self.norm2(x + ffn)

class LearnablePositionEmbedding(layers.Layer):
    def __init__(self, max_len, d_model, **kwargs):
        super().__init__(**kwargs)
        self.emb = layers.Embedding(input_dim=max_len, output_dim=d_model)

    def call(self, x):
        T = tf.shape(x)[1]
        pos = tf.range(0, T)
        return x + self.emb(pos)

def make_patch_transformer(seq_len, n_channels, n_classes, patch_size):
    inp = layers.Input(shape=(seq_len, n_channels))

    x = layers.Conv1D(
        filters=D_MODEL,
        kernel_size=patch_size,
        strides=patch_size,
        padding="valid"
    )(inp)

    max_tokens = int(np.ceil(seq_len / patch_size)) + 4
    x = LearnablePositionEmbedding(max_len=max_tokens, d_model=D_MODEL)(x)
    x = layers.Dropout(DROPOUT)(x)

    for _ in range(NUM_BLOCKS):
        x = TransformerBlock(d_model=D_MODEL, num_heads=NUM_HEADS, ff_dim=FF_DIM, dropout=DROPOUT)(x)

    x = layers.GlobalAveragePooling1D()(x)
    x = layers.Dropout(DROPOUT)(x)
    out = layers.Dense(n_classes, activation="sigmoid")(x)

    return models.Model(inp, out)

def measure_inference(model, X):
    out = []
    for bs in INF_BATCH_SIZES:
        n_total = min(len(X), bs * INF_N_BATCHES)
        Xb = X[:n_total]

        for _ in range(INF_WARMUP_BATCHES):
            _ = model.predict(Xb[: min(bs, n_total)], batch_size=bs, verbose=0)

        rss_before = get_process_rss_mb()
        gpu_before = get_gpu_mem_mb(GPU_INDEX)

        t0 = time.perf_counter()
        _ = model.predict(Xb, batch_size=bs, verbose=0)
        wall = time.perf_counter() - t0

        rss_after = get_process_rss_mb()
        gpu_after = get_gpu_mem_mb(GPU_INDEX)

        ms_per_sample = (wall * 1000.0) / max(1, n_total)
        samples_per_s = n_total / max(1e-9, wall)

        out.append(InferenceStats(
            batch_size=int(bs),
            n_samples=int(n_total),
            wall_s=float(wall),
            ms_per_sample=float(ms_per_sample),
            samples_per_s=float(samples_per_s),
            rss_mb_before=float(rss_before),
            rss_mb_after=float(rss_after),
            gpu_mem_before=gpu_before,
            gpu_mem_after=gpu_after,
        ))
    return out

def compute_per_class_metrics(y_true, y_prob, threshold=0.5):
    y_pred = (y_prob >= threshold).astype(int)
    precision, recall, f1, support = precision_recall_fscore_support(
        y_true, y_pred, average=None, zero_division=0
    )

    rows = []
    for i, cls in enumerate(TARGET_SUPER):
        rows.append({
            "Class": cls,
            "Precision": float(precision[i]),
            "Recall": float(recall[i]),
            "F1": float(f1[i]),
            "Support": int(support[i]),
        })
    return rows

def compute_curve_data(y_true, y_prob):
    y_true_flat = y_true.ravel()
    y_prob_flat = y_prob.ravel()

    fpr, tpr, _ = roc_curve(y_true_flat, y_prob_flat)
    prec, rec, _ = precision_recall_curve(y_true_flat, y_prob_flat)

    return {
        "roc_curve": {
            "fpr": fpr.tolist(),
            "tpr": tpr.tolist(),
        },
        "pr_curve": {
            "precision": prec.tolist(),
            "recall": rec.tolist(),
        }
    }

def train_and_eval_patch_transformer(X, y, label, data_meta):
    print("\n==============================")
    print(f"Patch-Transformer training on {label}")
    print("==============================")

    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.2, random_state=SEED,
        stratify=np.argmax(y, axis=1)
    )

    X_train, X_val, y_train, y_val = train_test_split(
        X_train, y_train, test_size=0.2, random_state=SEED,
        stratify=np.argmax(y_train, axis=1)
    )

    seq_len = X.shape[1]
    patch_size, bs = pick_patch_and_batch(seq_len)
    approx_tokens = int(np.ceil(seq_len / patch_size))

    print(f"seq_len={seq_len} | patch_size={patch_size} | tokens~{approx_tokens} | batch_size={bs}")

    model = make_patch_transformer(
        seq_len=seq_len,
        n_channels=X.shape[2],
        n_classes=len(TARGET_SUPER),
        patch_size=patch_size
    )

    model.compile(
        optimizer=optimizers.Adam(1e-3),
        loss="binary_crossentropy",
        metrics=[tf.keras.metrics.AUC(curve="ROC", multi_label=True, name="auc_roc")]
    )

    timer = EpochTimer()
    rss_before = get_process_rss_mb()
    gpu_before = get_gpu_mem_mb(GPU_INDEX)

    t0 = time.perf_counter()
    model.fit(
        X_train, y_train,
        validation_data=(X_val, y_val),
        epochs=EPOCHS,
        batch_size=bs,
        verbose=1,
        callbacks=[timer]
    )
    train_wall = time.perf_counter() - t0

    rss_after = get_process_rss_mb()
    gpu_after = get_gpu_mem_mb(GPU_INDEX)

    y_prob = model.predict(X_test, batch_size=bs, verbose=0)
    y_pred = (y_prob >= 0.5).astype(int)

    subset_accuracy = float(np.mean(np.all(y_pred == y_test.astype(int), axis=1)))

    metrics = {
        "roc_auc_micro": float(roc_auc_score(y_test, y_prob, average="micro")),
        "roc_auc_macro": float(roc_auc_score(y_test, y_prob, average="macro")),
        "pr_auc_micro": float(average_precision_score(y_test, y_prob, average="micro")),
        "pr_auc_macro": float(average_precision_score(y_test, y_prob, average="macro")),
        "accuracy": subset_accuracy,
    }

    # ---------------------------------------------------------
    # BOOTSTRAPPED CONFIDENCE INTERVALS
    # Computed on the same held-out test set as point estimates.
    # bootstrap_cis  -> overall metrics (ROC-AUC, PR-AUC, accuracy)
    # per_class_cis  -> per-class ROC-AUC and F1
    # ---------------------------------------------------------
    bootstrap_cis = compute_all_bootstrap_cis(y_test, y_prob)
    per_class_cis = compute_per_class_bootstrap_cis(y_test, y_prob)
    # ---------------------------------------------------------

    per_class_metrics = compute_per_class_metrics(y_test, y_prob, threshold=0.5)
    curve_data = compute_curve_data(y_test, y_prob)
    inference_stats = measure_inference(model, X_test)

    epoch_times = timer.epoch_times
    epoch_mean = float(np.mean(epoch_times)) if epoch_times else float("nan")
    epoch_median = float(np.median(epoch_times)) if epoch_times else float("nan")

    profile = {
        "label": label,
        "model_type": "Patch Transformer",
        "n_train": int(len(X_train)),
        "n_val": int(len(X_val)),
        "n_test": int(len(X_test)),
        "epochs": int(EPOCHS),
        "batch_size": int(bs),
        "seq_len": int(seq_len),
        "patch_size": int(patch_size),
        "approx_tokens": int(approx_tokens),
        "train_wall_s": float(train_wall),
        "epoch_times_s": [float(x) for x in epoch_times],
        "epoch_time_mean_s": epoch_mean,
        "epoch_time_median_s": epoch_median,
        "rss_mb_before": float(rss_before),
        "rss_mb_after": float(rss_after),
        "gpu_mem_before": gpu_before,
        "gpu_mem_after": gpu_after,
        "n_params": int(model.count_params()),
        "est_checkpoint_mb": float(estimate_model_checkpoint_mb(model)),
        "metrics": metrics,
        "bootstrap_cis": bootstrap_cis,        # <-- NEW
        "per_class_cis": per_class_cis,        # <-- NEW
        "per_class_metrics": per_class_metrics,
        "curve_data": curve_data,
        "inference": [asdict(x) for x in inference_stats],
        "data_meta": data_meta,
    }

    print("\nROC-AUC")
    print("Micro:", metrics["roc_auc_micro"])
    print("Macro:", metrics["roc_auc_macro"])

    print("\nPR-AUC")
    print("Micro:", metrics["pr_auc_micro"])
    print("Macro:", metrics["pr_auc_macro"])

    print("\nAccuracy")
    print("Exact-match multilabel accuracy:", metrics["accuracy"])

    return model, profile


